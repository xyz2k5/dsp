clc;
clear;
clf;

x = [1 2 3 4 5 6 7 8];   // given sequence
D = 2;

n = 0:length(x)-1;

subplot(2,1,1);
plot2d3(n, x);
title("Original Sequence");
xlabel("n");
ylabel("x(n)");

y = x(1:D:$);   // decimation
m = 0:length(y)-1;

subplot(2,1,2);
plot2d3(m, y);
title("Decimated Sequence");
xlabel("m");
ylabel("y(m)");
